generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id              Int           @id @default(autoincrement())
  orderNumber     String        @unique
  customerId      Int
  customerName    String
  status          String
  total_amount    Int           
  orderDate       DateTime
  deliveryDate    DateTime?
  
  customer        Customer      @relation(fields: [customerId], references: [id]) 
  orderItems      OrderItem[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@map("order")
}

model OrderItem {
  id             Int     @id @default(autoincrement())
  orderId        Int
  productId      Int
  quantity       Int
  unit_price     Int     
  total_amount   Int     
  Order          Order   @relation(fields: [orderId], references: [id])
  Product        Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("orderItem")
}

model Product {
  id                   Int      @id @default(autoincrement())
  sku                  String   @unique
  name                 String
  description          String?
  
  sourceCategoryCode   String
  specificCategory     String?
  rate                 String?
  page                 String?
  age                  String?  
  
  price                Int      
  currency             String   @default("GHS")
  stock                Int      @default(0)
  isActive             Boolean  @default(true)
  imageUrl             String?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) 
  
  OrderItem            OrderItem[]
  StockMovement        StockMovement[]
  bookingItems         BookingItem[]
  
  @@map("product")
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  productId Int
  type      String
  quantity  Int
  date      DateTime
  notes     String?
  reference String?  // <--- Ensure this line exists

  Product   Product  @relation(fields: [productId], references: [id])
  @@index([productId])
  @@map("stockMovement")
}

enum StockType {
  StockIn
  StockOut
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   
  name      String?
  role      String   @default("Staff") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("user")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  phone     String?
  
  orders    Order[] 
  bookings Booking[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("customer")
}

model Booking {
  id           Int           @id @default(autoincrement())
  customerId   Int
  customer     Customer      @relation(fields: [customerId], references: [id])
  eventDate    DateTime
  startTime    String?       // e.g., "10:00 AM"
  endTime      String?       // e.g., "04:00 PM"
  venueAddress String
  totalAmount  Int           // In cents
  status       String        @default("pending") // pending, confirmed, completed, cancelled
  items        BookingItem[]
  createdAt    DateTime      @default(now())

  @@map("booking")
}

model BookingItem {
  id        Int     @id @default(autoincrement())
  bookingId Int
  booking   Booking @relation(fields: [bookingId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int     // Price at time of booking (in cents)

  @@map("bookingItem")
}